# ==================== 环境配置 ====================
# 运行环境: development | staging | production
NODE_ENV=development

# ==================== API配置 ====================
# API基础路径（B端）
VITE_API_BASE_URL=http://localhost:8001/api/mer

# ==================== 功能开关 ====================
# 是否启用调试模式
VITE_DEBUG=true

# ==================== 网络配置 ====================
# 请求超时时间（毫秒）
VITE_REQUEST_TIMEOUT=30000

# ==================== 存储配置 ====================
# Token存储键名
VITE_TOKEN_KEY=mer_token
