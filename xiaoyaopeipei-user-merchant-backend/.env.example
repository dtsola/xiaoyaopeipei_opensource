# ==================== 应用配置 ====================
# 环境类型: development | test | production
APP_ENV=development

# 是否启用调试模式（生产环境请设置为false）
APP_DEBUG=true

# 服务监听地址和端口
APP_HOST=0.0.0.0
APP_PORT=8001

# ==================== 数据库配置 ====================
# MySQL数据库连接URL
# 格式: mysql+pymysql://用户名:密码@主机:端口/数据库名?charset=utf8mb4
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/xiaoyaopeipei?charset=utf8mb4

# ==================== JWT配置 ====================
# JWT密钥（生产环境请务必修改为随机字符串）
JWT_SECRET=your_jwt_secret_key_change_in_production

# JWT加密算法（默认HS256，无需修改）
JWT_ALGORITHM=HS256

# Token有效期（分钟），10080 = 7天
JWT_EXPIRE_MINUTES=10080

# ==================== 通义千问配置 ====================
# 通义千问API密钥
QWEN_API_KEY=sk-your_qwen_api_key_here

# 使用的模型（qwen-plus | qwen-turbo | qwen-max）
QWEN_MODEL=qwen-max

# 温度参数（0-1，越高越随机）
QWEN_TEMPERATURE=0.7

# 最大token数
QWEN_MAX_TOKENS=2000

# ==================== 阿里云OSS配置 ====================
# OSS访问密钥ID
OSS_ACCESS_KEY_ID=your_oss_access_key_id

# OSS访问密钥Secret
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret

# OSS存储桶名称
OSS_BUCKET=your_bucket_name

# OSS终端节点
OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com

# OSS区域
OSS_REGION=cn-shanghai

# OSS自定义域名（用于文件访问）
OSS_HOST=https://file.xiaoyaosai.com

# OSS STS角色ARN（可选，用于生成临时凭证）
# 格式: acs:ram::<主账号ID>:role/<角色名>
# 留空则使用永久AccessKey（不推荐生产环境）
OSS_STS_ROLE_ARN=

# ==================== 缓存配置 ====================
# 缓存最大条目数
CACHE_MAX_SIZE=1000

# 缓存默认过期时间（秒）
CACHE_TTL=3600

# ==================== 加密配置 ====================
# AES加密密钥（32位字符串）
AES_KEY=your_aes_key_32_characters_long

# ==================== 日志配置 ====================
# 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# 日志轮转时间（每天0点）
LOG_ROTATION=00:00

# 日志保留时间
LOG_RETENTION=30 days

# 日志格式
LOG_FORMAT=<green>{time:YYYY-MM-DD HH:mm:ss}</green> | <level>{level: <8}</level> | <cyan>{name}</cyan>:<cyan>{function}</cyan>:<cyan>{line}</cyan> - <level>{message}</level>

# ==================== 前端URL配置 ====================
# C端（用户端）前端地址
USER_FRONTEND_URL=http://localhost:5174

# C端生产环境地址
USER_FRONTEND_URL_PROD=http://localhost:5174

# ==================== 会员配置 ====================
# 会员默认天数（注册时赠送）
MEMBERSHIP_DEFAULT_DAYS=7

# 会员续期提醒阈值（天）
MEMBERSHIP_RENEWAL_THRESHOLD=3

# ==================== CORS配置 ====================
# CORS允许的域名（JSON数组格式，开发环境）
CORS_ORIGINS=["*"]

# CORS生产环境域名（JSON数组格式）
CORS_ORIGINS_PROD=["*"]

# 是否允许携带凭证
CORS_ALLOW_CREDENTIALS=true

# 允许的HTTP方法（JSON数组格式）
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","OPTIONS","PATCH"]

# 允许的请求头（"*"表示允许所有）
CORS_ALLOW_HEADERS=["*"]
