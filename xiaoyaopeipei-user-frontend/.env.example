# ==================== 环境配置 ====================
# 运行环境: development | staging | production
NODE_ENV=development

# ==================== 应用配置 ====================
# 应用标题
VITE_APP_TITLE=小遥配配 - AI电脑导购

# ==================== API配置 ====================
# API基础路径（C端）
VITE_API_BASE_URL=http://localhost:8001/api/user

# 商户端后台地址（用于跳转）
VITE_MER_BACKEND_URL=http://localhost:5174

# ==================== OSS配置 ====================
# OSS访问域名（用于图片/文件访问）
VITE_OSS_DOMAIN=https://xiaoyaopeipei.oss-cn-shanghai.aliyuncs.com

# ==================== 功能开关 ====================
# 是否启用Mock数据
VITE_USE_MOCK=false

# 是否启用调试模式
VITE_DEBUG=true

# ==================== 网络配置 ====================
# 请求超时时间（毫秒）
VITE_REQUEST_TIMEOUT=30000

# ==================== 存储配置 ====================
# 会话存储键名
VITE_SESSION_KEY=user_session

# ==================== 业务配置 ====================
# 最大推荐结果数量
VITE_MAX_RECOMMEND_COUNT=5
